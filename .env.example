API_ID=your_api_id_here
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
PREFIX=!

# Delay acak antar pesan (detik) untuk menghindari throttling
# Format: MIN-MAX (delay acak antara nilai ini)
# Set RATE_LIMIT_MAX=0 untuk menonaktifkan
RATE_LIMIT_MIN=4
RATE_LIMIT_MAX=5

DATABASE_URL=postgresql://postgres:your_password_here@db.your_supabase_url.supabase.co:5432/postgres